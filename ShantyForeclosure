<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Shanty Real Estate – Foreclosure Home Selling</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --white: #ffffff;
    --off-white: #fafafa;
    --light-gray: #f4f4f4;
    --border: #e8e8e8;
    --text: #111111;
    --muted: #888888;
    --gold: #c9a84c;
    --gold-dark: #a8873a;
    --gold-light: #e8d5a3;
    --charcoal: #1a1a1a;
    --shadow: rgba(0,0,0,0.07);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--white);
    color: var(--text);
    overflow-x: hidden;
  }

  /* ══ NAVBAR ══ */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    height: 68px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    transition: box-shadow 0.4s ease, background 0.4s ease;
  }
  nav.scrolled { box-shadow: 0 2px 32px rgba(0,0,0,0.09); }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.45rem; font-weight: 600;
    color: var(--charcoal); cursor: pointer; letter-spacing: 0.02em;
  }
  .nav-logo span { color: var(--gold); font-style: italic; }

  .nav-links { display: flex; gap: 0; list-style: none; align-items: center; }
  .nav-item { position: relative; }

  .nav-btn {
    background: none; border: none; cursor: pointer;
    font-family: 'Jost', sans-serif; font-size: 0.82rem;
    font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted); padding: 10px 18px; border-radius: 6px;
    transition: color 0.25s ease, background 0.25s ease;
    position: relative;
  }
  .nav-btn:hover, .nav-btn.active { color: var(--charcoal); background: var(--light-gray); }

  .nav-underline {
    position: absolute; bottom: -1px; left: 50%; transform: translateX(-50%);
    height: 2px; background: var(--gold); border-radius: 2px;
    width: 0; transition: width 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .nav-btn.active .nav-underline, .nav-btn:hover .nav-underline { width: 60%; }

  .dropdown {
    position: absolute; top: calc(100% + 12px); left: 50%;
    background: var(--white); border: 1px solid var(--border); border-radius: 12px;
    padding: 8px; min-width: 230px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.1);
    opacity: 0; visibility: hidden;
    transform: translateX(-50%) translateY(10px);
    transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
    pointer-events: none;
  }
  .nav-item:hover .dropdown {
    opacity: 1; visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: all;
  }
  .dropdown a {
    display: block; padding: 10px 14px; font-size: 0.88rem; color: var(--text);
    text-decoration: none; border-radius: 8px; transition: background 0.15s ease;
  }
  .dropdown a:hover { background: var(--light-gray); color: var(--gold-dark); }

  /* Shimmer CTA button */
  .nav-cta {
    position: relative; overflow: hidden;
    background: var(--charcoal); color: var(--white);
    padding: 10px 22px; border-radius: 50px;
    font-family: 'Jost', sans-serif; font-size: 0.78rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.1); cursor: pointer;
    transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
    margin-left: 12px; z-index: 0;
    --shimmer-color: rgba(255,255,255,0.6);
  }
  .nav-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: conic-gradient(from 270deg, transparent, var(--shimmer-color), transparent);
    animation: shimmer-spin 3s linear infinite;
    border-radius: inherit;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .nav-cta::after {
    content: '';
    position: absolute;
    inset: 1.5px;
    background: var(--charcoal);
    border-radius: 50px;
    z-index: -1;
    transition: background 0.3s ease;
  }
  .nav-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(201,168,76,0.35); }
  .nav-cta:hover::before { opacity: 1; }
  .nav-cta:hover::after { background: var(--gold-dark); }

  @keyframes shimmer-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .hamburger { display: none; background: none; border: none; cursor: pointer; padding: 8px; flex-direction: column; gap: 5px; }
  .hamburger span { display: block; width: 22px; height: 2px; background: var(--charcoal); transition: all 0.3s; }

  /* ══ PAGES ══ */
  .page { display: none; min-height: 100vh; padding-top: 68px; }
  .page.active { display: block; animation: pageIn 0.55s cubic-bezier(0.4,0,0.2,1) forwards; }

  @keyframes pageIn {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ══ HERO ══ */
  .hero {
    position: relative; min-height: calc(100vh - 68px);
    display: flex; align-items: center; justify-content: center;
    background: var(--white); overflow: hidden;
  }

  .paths-svg {
    position: absolute; inset: 0; width: 100%; height: 100%;
    pointer-events: none;
  }
  .paths-svg path {
    stroke: #111; stroke-opacity: 0.05; fill: none;
    animation: drawPath 24s linear infinite;
    stroke-dasharray: 1200; stroke-dashoffset: 1200;
  }
  @keyframes drawPath {
    0%   { stroke-dashoffset: 1200; opacity: 0.3; }
    50%  { stroke-dashoffset: 0;    opacity: 0.08; }
    100% { stroke-dashoffset: -1200; opacity: 0.3; }
  }

  .hero-content {
    position: relative; z-index: 2;
    text-align: center; padding: 60px 24px; max-width: 900px;
  }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--gold-dark); border: 1px solid rgba(201,168,76,0.35);
    padding: 7px 20px; border-radius: 50px; margin-bottom: 32px;
    background: rgba(201,168,76,0.06);
    animation: fadeUp 0.7s 0.1s both;
  }

  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 7vw, 5.5rem); font-weight: 300;
    color: var(--charcoal); line-height: 1.1; margin-bottom: 28px;
    animation: fadeUp 0.7s 0.2s both;
  }
  .hero h1 .word { display: inline-block; margin-right: 0.25em; }
  .hero h1 .letter { display: inline-block; animation: letterDrop 0.6s both; }
  .hero h1 em { font-style: italic; color: var(--gold); }

  @keyframes letterDrop {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero p {
    font-size: 1.05rem; color: var(--muted); line-height: 1.85;
    max-width: 580px; margin: 0 auto 40px;
    animation: fadeUp 0.7s 0.4s both;
  }

  .hero-btns {
    display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;
    animation: fadeUp 0.7s 0.5s both;
  }

  .btn-dark {
    background: var(--charcoal); color: var(--white);
    font-family: 'Jost', sans-serif; font-size: 0.8rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 14px 36px; border: none; border-radius: 10px; cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .btn-dark:hover { background: var(--gold); color: var(--charcoal); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(201,168,76,0.4); }

  .btn-ghost {
    background: transparent; color: var(--charcoal);
    font-family: 'Jost', sans-serif; font-size: 0.8rem; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 13px 36px; border: 1.5px solid var(--border); border-radius: 10px; cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold-dark); transform: translateY(-2px); }

  .scroll-hint {
    position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    animation: fadeUp 0.7s 0.8s both;
  }
  .scroll-hint span { font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase; color: #bbb; }
  .scroll-line {
    width: 1px; height: 40px; background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse { 0%,100%{opacity:0.3;transform:scaleY(0.7)} 50%{opacity:1;transform:scaleY(1)} }

  /* ══ STATS BAR ══ */
  .stats-bar {
    background: var(--charcoal);
    display: flex; justify-content: center;
  }
  .stat-item {
    padding: 32px 56px; text-align: center;
    border-right: 1px solid rgba(255,255,255,0.08);
    transition: background 0.3s ease;
  }
  .stat-item:last-child { border-right: none; }
  .stat-item:hover { background: rgba(255,255,255,0.04); }
  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem; font-weight: 600; color: var(--gold); display: block;
  }
  .stat-label { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.4); }

  /* ══ SECTION ══ */
  .section { padding: 80px 48px; }
  .section-inner { max-width: 1200px; margin: 0 auto; }

  .label {
    font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold-dark); margin-bottom: 10px; display: block;
  }
  .title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 400;
    color: var(--charcoal); line-height: 1.2; margin-bottom: 16px;
  }
  .sub { font-size: 0.97rem; color: var(--muted); line-height: 1.85; max-width: 600px; }
  .divider { width: 40px; height: 2px; background: linear-gradient(90deg, var(--gold), transparent); margin: 20px 0 44px; }

  /* ══ HOME: Split layout ══ */
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
  .split-img {
    border-radius: 20px; overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.12); aspect-ratio: 4/3;
    position: relative;
  }
  .split-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s cubic-bezier(0.4,0,0.2,1); }
  .split-img:hover img { transform: scale(1.04); }
  /* Glowing border effect on image */
  .split-img::after {
    content: '';
    position: absolute; inset: -2px;
    border-radius: 22px;
    background: conic-gradient(from 0deg, var(--gold), transparent 40%, var(--gold-light), transparent 80%, var(--gold));
    z-index: -1;
    opacity: 0;
    transition: opacity 0.5s ease;
    animation: glow-rotate 4s linear infinite;
  }
  .split-img:hover::after { opacity: 1; }
  @keyframes glow-rotate { from { filter: hue-rotate(0deg); } to { filter: hue-rotate(360deg); } }

  .split-text p { font-size: 0.97rem; line-height: 1.9; color: #555; margin-bottom: 16px; }

  /* ══ FEATURE CARDS ══ */
  .feature-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; margin-top: 48px; }

  .feature-card {
    background: var(--off-white); border: 1px solid var(--border);
    border-radius: 16px; padding: 36px 28px;
    transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
    position: relative; overflow: hidden;
  }
  .feature-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.4s ease;
  }
  .feature-card:hover { box-shadow: 0 20px 52px rgba(0,0,0,0.1); transform: translateY(-5px); border-color: transparent; }
  .feature-card:hover::before { transform: scaleX(1); }
  .feature-icon { font-size: 2rem; margin-bottom: 18px; }
  .feature-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--charcoal); margin-bottom: 10px; }
  .feature-card p { font-size: 0.88rem; line-height: 1.8; color: var(--muted); }

  /* ══ SCROLL EXPANSION HERO (inline recreation) ══ */
  .scroll-expand-section {
    position: relative;
    background: #0d0d0d;
    min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    overflow: hidden;
    padding: 80px 24px;
  }
  .scroll-expand-bg {
    position: absolute; inset: 0;
    background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1920&q=80');
    background-size: cover; background-position: center;
    opacity: 0.18; transition: opacity 0.6s ease;
  }
  .scroll-expand-inner { position: relative; z-index: 2; text-align: center; max-width: 900px; }
  .scroll-expand-inner h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3.6rem); font-weight: 300;
    color: var(--white); line-height: 1.2; margin-bottom: 20px;
  }
  .scroll-expand-inner h2 em { color: var(--gold); font-style: italic; }
  .scroll-expand-inner p { font-size: 1rem; color: rgba(255,255,255,0.55); line-height: 1.85; max-width: 580px; margin: 0 auto 40px; }

  /* Media card that expands on hover */
  .expand-media-card {
    position: relative;
    width: 340px; height: 420px;
    border-radius: 20px; overflow: hidden;
    margin: 0 auto 48px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5);
    transition: width 0.7s cubic-bezier(0.4,0,0.2,1), height 0.7s cubic-bezier(0.4,0,0.2,1), border-radius 0.7s;
    cursor: pointer;
  }
  .expand-media-card.expanded {
    width: min(90vw, 900px);
    height: min(70vh, 540px);
    border-radius: 24px;
  }
  .expand-media-card img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.4,0,0.2,1);
  }
  .expand-media-card:hover img { transform: scale(1.04); }
  .expand-media-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 50%);
  }
  .expand-media-label {
    position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
    font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.7); white-space: nowrap;
    transition: opacity 0.4s ease;
  }
  .expand-media-card.expanded .expand-media-label { opacity: 0; }

  /* Timeline cards in dark section */
  .timeline-cards {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 20px;
    margin-top: 24px; text-align: left;
  }
  .timeline-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px; padding: 24px 20px;
    transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
    position: relative; overflow: hidden;
  }
  .timeline-card::before {
    content: '';
    position: absolute; inset: 0;
    background: conic-gradient(from var(--angle, 0deg) at 50% 50%, transparent 0deg, rgba(201,168,76,0.15) 60deg, transparent 120deg);
    opacity: 0;
    transition: opacity 0.4s;
    border-radius: inherit;
  }
  .timeline-card:hover { background: rgba(255,255,255,0.08); border-color: rgba(201,168,76,0.4); transform: translateY(-4px); }
  .timeline-card:hover::before { opacity: 1; }
  .timeline-card-num { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; color: var(--gold); margin-bottom: 10px; }
  .timeline-card h4 { font-size: 0.88rem; font-weight: 600; color: var(--white); margin-bottom: 6px; letter-spacing: 0.03em; }
  .timeline-card p { font-size: 0.8rem; color: rgba(255,255,255,0.45); line-height: 1.7; }

  /* ══ PAGE HEADER ══ */
  .page-header {
    background: var(--off-white); border-bottom: 1px solid var(--border);
    padding: 72px 48px 56px; position: relative; overflow: hidden;
  }
  .page-header::after {
    content: ''; position: absolute; bottom: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, var(--gold), transparent 60%);
  }
  .page-header-inner { max-width: 1200px; margin: 0 auto; }
  .page-header h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.2rem); font-weight: 300;
    color: var(--charcoal); line-height: 1.2; margin-top: 10px;
  }

  /* ══ ABOUT ══ */
  .about-grid { display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 72px; align-items: start; }
  .about-text p { font-size: 0.97rem; line-height: 1.9; color: #555; margin-bottom: 16px; }
  .about-text strong { color: var(--charcoal); }

  .cert-list { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; }
  .cert {
    font-size: 0.72rem; font-weight: 500; letter-spacing: 0.06em;
    padding: 6px 14px; border-radius: 50px;
    background: var(--charcoal); color: var(--gold-light);
  }

  /* Agent card with actual photo */
  .agent-card {
    background: var(--white); border: 1px solid var(--border);
    border-radius: 20px; overflow: hidden;
    box-shadow: 0 16px 52px rgba(0,0,0,0.09);
    position: relative;
    transition: box-shadow 0.4s ease, transform 0.4s ease;
  }
  .agent-card:hover { box-shadow: 0 24px 64px rgba(201,168,76,0.18); transform: translateY(-4px); }

  /* Glowing border on agent card */
  .agent-card::before {
    content: '';
    position: absolute; inset: 0;
    border-radius: 20px;
    padding: 1.5px;
    background: conic-gradient(from 0deg, var(--gold), transparent 40%, var(--gold-light), transparent 80%, var(--gold));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 1;
    animation: glow-rotate 4s linear infinite;
  }
  .agent-card:hover::before { opacity: 1; }

  .agent-photo-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
  }
  .agent-photo-wrap img {
    width: 100%; height: 100%; object-fit: cover; object-position: top center;
    transition: transform 0.7s cubic-bezier(0.4,0,0.2,1);
  }
  .agent-card:hover .agent-photo-wrap img { transform: scale(1.03); }

  .agent-card-body { padding: 28px; }
  .agent-card-body h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.7rem; color: var(--charcoal); margin-bottom: 2px; }
  .agent-role { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold-dark); margin-bottom: 16px; display: block; }
  .agent-card-body p { font-size: 0.85rem; color: var(--muted); line-height: 1.7; }
  .agent-contact { display: flex; flex-direction: column; gap: 6px; margin-top: 14px; }
  .agent-contact a { font-size: 0.88rem; color: var(--charcoal); text-decoration: none; font-weight: 500; transition: color 0.25s ease; }
  .agent-contact a:hover { color: var(--gold-dark); }

  .values-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-top: 56px; }
  .val-card {
    background: var(--off-white); border: 1px solid var(--border);
    border-radius: 12px; padding: 28px 24px;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .val-card:hover { box-shadow: 0 10px 32px rgba(0,0,0,0.08); transform: translateY(-4px); }
  .val-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; color: var(--charcoal); margin-bottom: 8px; }
  .val-card p { font-size: 0.86rem; line-height: 1.75; color: var(--muted); }

  /* ══ FORECLOSURE ACCORDION ══ */
  .accordion { display: flex; flex-direction: column; gap: 12px; }

  .acc-item {
    background: var(--white); border: 1px solid var(--border);
    border-radius: 14px; overflow: hidden;
    transition: box-shadow 0.35s ease, border-color 0.35s ease;
  }
  .acc-item.open { box-shadow: 0 8px 36px rgba(0,0,0,0.08); border-color: rgba(201,168,76,0.35); }

  .acc-header {
    display: flex; align-items: center; gap: 20px;
    padding: 24px 28px; cursor: pointer; transition: background 0.2s ease;
  }
  .acc-header:hover { background: var(--off-white); }

  .acc-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem; font-weight: 300; color: var(--gold); min-width: 44px;
  }
  .acc-title { flex: 1; }
  .acc-title h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; color: var(--charcoal); margin-bottom: 3px; }
  .acc-title p { font-size: 0.84rem; color: var(--muted); }

  .acc-arrow {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--off-white); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.9rem; color: var(--gold); font-weight: bold;
    transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
  }
  .acc-item.open .acc-arrow { background: var(--gold); color: var(--white); transform: rotate(45deg); }

